APP_ENV=development
FRONTEND_URL=http://localhost:5173

DATABASE_URL=sqlite:///./job_agent.db

SECRET_KEY=change-me-in-production

# SMTP is required to actually send verification emails. If left blank,
# emails are silently skipped (a warning is logged instead).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
FROM_NAME=AI Job Application Agent
