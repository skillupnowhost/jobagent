# Application
APP_NAME=AI Job Application Agent
APP_ENV=development
SECRET_KEY=your-secret-key-change-in-production
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=sqlite:///./job_agent.db
# For production: postgresql://user:password@host:5432/job_agent

# Auth / MFA
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_MFA_PENDING_EXPIRE_MINUTES=5
JWT_EMAIL_VERIFY_EXPIRE_HOURS=24
MFA_ISSUER_NAME=AI Job Application Agent

# Rate limiting (in-memory; must move to Redis-backed storage if gunicorn workers > 1)
RATE_LIMIT_REGISTER=5/hour
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_MFA_VERIFY=5/5minutes
RATE_LIMIT_RESEND_VERIFICATION=3/hour

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=Your Name

# Google Calendar API
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# Job Search APIs
RAPIDAPI_KEY=your-rapidapi-key
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# AI/NLP
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# AWS (for production deployment)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=ap-south-1

# User Profile
USER_NAME=Your Name
USER_EMAIL=your-email@gmail.com
USER_PHONE=+91-0000000000
USER_LOCATION=Chennai, Tamil Nadu, India
USER_LINKEDIN=www.linkedin.com/in/your-profile
USER_GITHUB=https://github.com/your-username
USER_EXPERIENCE_YEARS=0
USER_MIN_SALARY_LPA=10
